# Copy to backend/.env for local development (never commit .env)

# Database — local default is SQLite. On Render, set DATABASE_URL from your Postgres instance.
DATABASE_URL=sqlite:///./legal_knowledge_graph.db

# Comma-separated frontend URLs allowed to call the API (no trailing slash)
# Example: https://rialu-graph.vercel.app,http://localhost:5174
# When set, *.vercel.app origins are also allowed automatically.
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5174

# Future: LLM-assisted extraction (optional, not used yet)
# OPENAI_API_KEY=sk-...
